@inherits LayoutComponentBase
@implements IDisposable
@inject LocalStorageService Storage
@inject NavigationManager Nav

<MudThemeProvider Theme="_theme" IsDarkMode="_isDark" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Color="Color.Default"
               Style="border-bottom:1px solid; border-color:var(--mud-palette-divider);">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="() => _drawerOpen = !_drawerOpen" />
        <MudText Typo="Typo.h6" Style="font-weight:700;letter-spacing:-0.3px">FinTool</MudText>
        <MudSpacer />
        <MudTooltip Text="@(_isDark ? "Switch to light mode" : "Switch to dark mode")">
            <MudIconButton Icon="@(_isDark ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit"
                           OnClick="ToggleDarkMode" />
        </MudTooltip>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Variant="DrawerVariant.Temporary"
               Fixed="true"
               ClipMode="DrawerClipMode.Never"
               Elevation="2">
        <MudDrawerHeader Class="py-4 px-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Primary" />
                <MudText Typo="Typo.h6" Style="font-weight:700">FinTool</MudText>
            </MudStack>
        </MudDrawerHeader>
        <MudDivider Style="flex-grow:0" />
        <MudNavMenu Class="pa-2 pt-3">
            <MudNavLink Href="/"
                        Icon="@Icons.Material.Filled.Dashboard"
                        Match="NavLinkMatch.All">
                Dashboard
            </MudNavLink>
            <MudNavLink Href="/transactions"
                        Icon="@Icons.Material.Filled.Receipt">
                Transactions
            </MudNavLink>
            <MudNavLink Href="/budget"
                        Icon="@Icons.Material.Filled.Savings">
                Budget
            </MudNavLink>
            <MudNavLink Href="/revenue"
                        Icon="@Icons.Material.Filled.TrendingUp">
                Revenue
            </MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-6 px-4 px-md-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = false;
    private bool _isDark = false;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary           = "#344e41",
            Secondary         = "#a3b18a",
            AppbarBackground  = "#faf9f5",
            AppbarText        = "#1c1b1f",
            Background        = "#f5f2eb",
            Surface           = "#fffcf8",
            DrawerBackground  = "#ede9e2",
            DrawerText        = "#1c1b1f",
            DrawerIcon        = "#344e41",
            TextPrimary       = "#1c1b1f",
            TextSecondary     = "#4a4740",
            Divider           = "#d5cfc8",
            ActionDefault     = "#4a4740",
            TableLines        = "#e5e0d8",
            TableHover        = "#f0ece4",
        },
        PaletteDark = new PaletteDark
        {
            Primary           = "#a3b18a",
            Secondary         = "#dad7cd",
            AppbarBackground  = "#161d18",
            AppbarText        = "#dde4d9",
            Background        = "#0e1410",
            BackgroundGray    = "#161d18",
            Surface           = "#161d18",
            DrawerBackground  = "#161d18",
            DrawerText        = "#dde4d9",
            DrawerIcon        = "#a3b18a",
            TextPrimary       = "#dde4d9",
            TextSecondary     = "#8c9d89",
            Divider           = "#28342a",
            ActionDefault     = "#8c9d89",
            TableLines        = "#1c2b1e",
            TableHover        = "#192118",
        },
        Typography = new Typography
        {
            Default   = new Default   { FontFamily = ["Inter", "system-ui", "sans-serif"] },
            H5        = new H5        { FontFamily = ["Inter", "system-ui", "sans-serif"], FontWeight = 600 },
            H6        = new H6        { FontFamily = ["Inter", "system-ui", "sans-serif"], FontWeight = 600 },
            Subtitle1 = new Subtitle1 { FontFamily = ["Inter", "system-ui", "sans-serif"], FontWeight = 500 },
            Subtitle2 = new Subtitle2 { FontFamily = ["Inter", "system-ui", "sans-serif"], FontWeight = 500 },
            Button    = new MudBlazor.Button
            {
                FontFamily    = ["Inter", "system-ui", "sans-serif"],
                FontWeight    = 500,
                TextTransform = "none"
            }
        },
        LayoutProperties = new LayoutProperties
        {
            DrawerWidthLeft     = "268px",
            DefaultBorderRadius = "12px"
        }
    };

    protected override async Task OnInitializedAsync()
    {
        _isDark = await Storage.GetAsync<bool>("fintool_darkmode");
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _drawerOpen = false;
        StateHasChanged();
    }

    private async Task ToggleDarkMode()
    {
        _isDark = !_isDark;
        await Storage.SetAsync("fintool_darkmode", _isDark);
    }

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;
}
