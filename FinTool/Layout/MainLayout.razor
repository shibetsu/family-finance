@inherits LayoutComponentBase
@implements IDisposable
@inject LocalStorageService Storage
@inject NavigationManager Nav
@inject MonthState MonthSvc
@inject AuthService Auth
@inject AuthenticationStateProvider AuthStateProvider
@inject AppInfoService AppInfo
@inject IDialogService DialogSvc
@using System.Globalization

<MudThemeProvider Theme="AppTheme.Theme" IsDarkMode="_isDark" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Color="Color.Default"
               Style="border-bottom:1px solid; border-color:var(--mud-palette-divider);">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="() => _drawerOpen = !_drawerOpen" />
        <img src="fintool_preview.png" alt="Family Finance logo" style="height:28px;width:28px;object-fit:contain;" />
        <MudText Typo="Typo.h6" Style="font-weight:700;letter-spacing:-0.3px;margin-left:8px">Family Finance</MudText>
        <MudSpacer />

        <!-- Full prev/month/next picker — hidden on phones, where it crowds the logo onto two lines. -->
        <MudHidden Breakpoint="Breakpoint.Xs">
            <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                           Color="Color.Inherit"
                           OnClick="MonthSvc.PrevMonth" />
            <MudText Style="min-width:130px;text-align:center;font-size:0.875rem;font-weight:500">
                @MonthSvc.Month.ToString("MMMM yyyy", CultureInfo.InvariantCulture)
            </MudText>
            <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                           Color="Color.Inherit"
                           Disabled="@(MonthSvc.Month >= MonthSvc.CurrentMonth)"
                           OnClick="MonthSvc.NextMonth" />
        </MudHidden>

        <!-- Compact month label on phones — opens a dialog with the full picker. -->
        <MudHidden Breakpoint="Breakpoint.Xs" Invert="true">
            <MudButton Variant="Variant.Text"
                       Color="Color.Inherit"
                       OnClick="OpenMonthPickerAsync"
                       StartIcon="@Icons.Material.Filled.CalendarMonth"
                       Style="text-transform:none;font-size:0.8125rem;font-weight:500;min-width:0;padding:6px 10px">
                @MonthSvc.Month.ToString("MMM yyyy", CultureInfo.InvariantCulture)
            </MudButton>
        </MudHidden>

        <MudTooltip Text="@(_isDark ? "Switch to light mode" : "Switch to dark mode")">
            <MudIconButton Icon="@(_isDark ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit"
                           OnClick="ToggleDarkMode" />
        </MudTooltip>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Variant="DrawerVariant.Temporary"
               Fixed="true"
               ClipMode="DrawerClipMode.Never"
               Elevation="2">
        <div style="display:flex;align-items:center;padding:16px;gap:8px">
            <img src="fintool_preview.png" alt="Family Finance logo" style="height:32px;width:32px;object-fit:contain;" />
            <MudText Typo="Typo.h6" Style="font-weight:700">Family Finance</MudText>
        </div>
        <MudDivider Style="flex-grow:0" />
        <MudNavMenu Class="pa-2 pt-3">
            <MudNavLink Href="/" Icon="@NavIcons.Dashboard" Match="NavLinkMatch.All">Dashboard</MudNavLink>
            <MudNavLink Href="/transactions" Icon="@NavIcons.Transactions">Transactions</MudNavLink>
            <MudNavLink Href="/recurring" Icon="@NavIcons.Recurring">Recurring</MudNavLink>
            <MudNavLink Href="/budget-planner" Icon="@NavIcons.Planner">Planner</MudNavLink>
            <MudNavLink Href="/goals" Icon="@NavIcons.Goals">Goals</MudNavLink>
            <MudNavGroup Title="Settings" Icon="@NavIcons.Settings" Expanded="@_settingsOpen" ExpandedChanged="@(v => _settingsOpen = v)">
                @if (_isOwner)
                {
                    <MudNavLink Href="/settings/general" Icon="@NavIcons.General">General</MudNavLink>
                }
                <MudNavLink Href="/settings/budget" Icon="@NavIcons.Budget">Budget</MudNavLink>
                @if (_isOwner)
                {
                    <MudNavLink Href="/users" Icon="@NavIcons.Users">Users</MudNavLink>
                }
            </MudNavGroup>
        </MudNavMenu>
        <MudDivider Style="margin-top:auto;flex-grow:0" />
        <MudText Typo="Typo.caption" Style="display:block;padding:6px 16px 0;opacity:0.4;font-size:0.7rem;user-select:none;">v@_version</MudText>
        <div style="display:flex;align-items:center;padding:8px 16px 12px;gap:10px">
            <MudAvatar Style="width:32px;height:32px;font-size:0.8rem;background:var(--mud-palette-primary);color:var(--mud-palette-primary-text);flex-shrink:0">
                @(_displayName.Length > 0 ? _displayName[0].ToString().ToUpper() : "?")
            </MudAvatar>
            <div style="flex:1;overflow:hidden">
                <MudText Style="font-size:0.875rem;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                    @_displayName
                </MudText>
                @if (_displayName != _username)
                {
                    <MudText Style="font-size:0.75rem;opacity:0.55;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                        @@@_username
                    </MudText>
                }
            </div>
            <MudTooltip Text="Log out">
                <MudIconButton Icon="@Icons.Material.Filled.Logout"
                               Size="Size.Small"
                               OnClick="LogoutAsync" />
            </MudTooltip>
        </div>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-6 px-4 px-md-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool   _drawerOpen   = false;
    private bool   _isDark       = false;
    private bool   _settingsOpen = false;
    private string _username     = "";
    private string _displayName  = "";
    private bool   _isOwner      = false;
    private string _version      = "";

    private IDisposable? _locationChangingReg;

    protected override async Task OnInitializedAsync()
    {
        _isDark = await Storage.GetAsync<bool>("fintool_darkmode");
        Nav.LocationChanged += OnLocationChanged;
        MonthSvc.OnChange   += OnMonthChanged;
        _locationChangingReg = Nav.RegisterLocationChangingHandler(OnLocationChanging);
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        _username    = auth.User.Identity?.Name ?? "";
        _displayName = auth.User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value ?? _username;
        _isOwner     = auth.User.IsInRole("Owner");
        _version     = await AppInfo.GetVersionAsync();
        _settingsOpen = Nav.Uri.Contains("/settings") || Nav.Uri.Contains("/users");
    }

    private async Task LogoutAsync()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/login", replace: true);
    }

    private async ValueTask OnLocationChanging(LocationChangingContext _)
    {
        if (!_drawerOpen) return;
        _drawerOpen = false;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(250);
    }

    private void OnMonthChanged() => InvokeAsync(StateHasChanged);

    private async Task OpenMonthPickerAsync()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        await DialogSvc.ShowAsync<MonthPickerDialog>("Select Month", options);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _drawerOpen = false;
        if (Nav.Uri.Contains("/settings") || Nav.Uri.Contains("/users"))
            _settingsOpen = true;
        StateHasChanged();
    }

    private async Task ToggleDarkMode()
    {
        _isDark = !_isDark;
        await Storage.SetAsync("fintool_darkmode", _isDark);
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        MonthSvc.OnChange   -= OnMonthChanged;
        _locationChangingReg?.Dispose();
    }
}
