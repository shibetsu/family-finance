@inject BudgetService BudgetSvc
@inject IDialogService DialogSvc

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5">Budget</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="AddCategory">
        Add Category
    </MudButton>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_categories.Count == 0)
{
    <MudAlert Severity="Severity.Info" Class="mt-2">
        No categories yet. Add one to start budgeting.
    </MudAlert>
}
else
{
    <MudTable T="BudgetCategory" Items="_categories" Hover="true" Elevation="1">
        <HeaderContent>
            <MudTh>Category</MudTh>
            <MudTh Style="text-align:right">Monthly Budget</MudTh>
            <MudTh Style="text-align:right">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Category">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2"
                          Style="@(context.IsIgnored ? "opacity:0.45" : "")">
                    <MudIcon Icon="@Icons.Material.Filled.Circle"
                             Style="@($"color:{context.Color}")" Size="Size.Small" />
                    <MudText>@context.Name</MudText>
                    @if (context.IsIgnored)
                    {
                        <MudTooltip Text="Excluded from dashboard and totals">
                            <MudIcon Icon="@Icons.Material.Filled.VisibilityOff"
                                     Size="Size.Small" Color="Color.Default" />
                        </MudTooltip>
                    }
                </MudStack>
            </MudTd>
            <MudTd DataLabel="Monthly Budget" Style="text-align:right"
                   Class="@(context.IsIgnored ? "mud-text-secondary" : "")">
                @($"${context.MonthlyAmount:N2}")
            </MudTd>
            <MudTd Style="text-align:right">
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                               Size="Size.Small"
                               OnClick="() => EditCategory(context)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                               Size="Size.Small" Color="Color.Error"
                               OnClick="() => DeleteCategory(context)" />
            </MudTd>
        </RowTemplate>
    </MudTable>

    <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-3 pr-2">
        <MudText Typo="Typo.subtitle2">Total monthly budget:</MudText>
        <MudText Typo="Typo.subtitle2" Color="Color.Primary">
            @($"${_categories.Where(c => !c.IsIgnored).Sum(c => c.MonthlyAmount):N2}")
        </MudText>
    </MudStack>
}

@code {
    private List<BudgetCategory> _categories = [];
    private bool _loading = true;

    private static readonly DialogOptions _dialogOptions =
        new() { MaxWidth = MaxWidth.Small, FullWidth = true };

    protected override async Task OnInitializedAsync()
    {
        _categories = await BudgetSvc.GetCategoriesAsync();
        _loading = false;
    }

    private async Task AddCategory()
    {
        var category = new BudgetCategory();
        var parameters = new DialogParameters<CategoryDialog> { { x => x.Category, category } };
        var dialog = await DialogSvc.ShowAsync<CategoryDialog>("Add Category", parameters, _dialogOptions);
        if ((await dialog.Result) is { Canceled: false })
        {
            await BudgetSvc.SaveAsync(category);
            _categories = await BudgetSvc.GetCategoriesAsync();
        }
    }

    private async Task EditCategory(BudgetCategory original)
    {
        var copy = new BudgetCategory
        {
            Id            = original.Id,
            Name          = original.Name,
            MonthlyAmount = original.MonthlyAmount,
            Color         = original.Color,
            IsIgnored     = original.IsIgnored
        };
        var parameters = new DialogParameters<CategoryDialog> { { x => x.Category, copy } };
        var dialog = await DialogSvc.ShowAsync<CategoryDialog>("Edit Category", parameters, _dialogOptions);
        if ((await dialog.Result) is { Canceled: false })
        {
            await BudgetSvc.SaveAsync(copy);
            _categories = await BudgetSvc.GetCategoriesAsync();
        }
    }

    private async Task DeleteCategory(BudgetCategory category)
    {
        var confirmed = await DialogSvc.ShowMessageBox(
            "Delete Category",
            $"Delete \"{category.Name}\"? This cannot be undone.",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed == true)
        {
            await BudgetSvc.DeleteAsync(category.Id);
            _categories = await BudgetSvc.GetCategoriesAsync();
        }
    }
}
