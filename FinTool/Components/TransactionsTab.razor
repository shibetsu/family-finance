<style>
    .cat-select .mud-input { font-size: 0.875rem; }
</style>
@using System.Globalization
@using FinTool.Models
@using FinTool.Services
@inject TransactionService TxSvc
@inject BudgetService BudgetSvc
@inject RevenueCategoryService RevenueSvc
@inject ClosedMonthService ClosedMonthSvc
@inject MerchantCacheService CacheSvc
@inject AccountService AccountSvc
@inject GoalService GoalSvc
@inject IDialogService DialogSvc
@inject TransactionFilterState FilterState
@inject NavigationManager Nav
@inject MonthState MonthSvc
@implements IDisposable

<!-- Header -->
<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    @if (!string.IsNullOrEmpty(InitialCategory))
    {
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                       Title="Back to Dashboard"
                       OnClick="@(() => Nav.NavigateTo($"/?month={MonthSvc.Month:yyyy-MM}"))" />
    }
    <MudText Typo="Typo.h5">Transactions</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Outlined"
               StartIcon="@Icons.Material.Filled.Lock"
               Disabled="@(MonthSvc.Month >= MonthSvc.CurrentMonth || _isMonthClosed)"
               OnClick="CloseMonthAsync">
        Close Month
    </MudButton>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.CloudUpload"
               OnClick="OpenImportAsync">
        Import
    </MudButton>
</MudStack>

<!-- Confirmed transactions -->
@if (_loading)
{
    <LoadingOverlay />
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px">
        <div class="sk" style="height:18px;width:180px"></div>
        <div style="flex:1"></div>
        <div class="sk" style="height:30px;width:30px;border-radius:50%"></div>
        <div class="sk" style="height:30px;width:30px;border-radius:50%"></div>
    </div>
    <MudPaper Elevation="1" Class="overflow-hidden">
        <!-- header -->
        <div style="display:flex;gap:12px;padding:13px 16px;border-bottom:1px solid var(--mud-palette-table-lines)">
            <div class="sk" style="height:13px;width:16px"></div>
            <div class="sk" style="height:13px;width:70px"></div>
            <div class="sk" style="height:13px;width:180px"></div>
            <div class="sk" style="height:13px;width:100px"></div>
            <div style="flex:1"></div>
            <div class="sk" style="height:13px;width:65px"></div>
        </div>
        @for (var r = 0; r < 10; r++)
        {
            <div style="display:flex;align-items:center;gap:12px;padding:10px 16px;border-bottom:1px solid var(--mud-palette-table-lines)">
                <div class="sk" style="width:16px;height:16px;border-radius:3px;flex-shrink:0"></div>
                <div class="sk" style="height:14px;width:80px;flex-shrink:0"></div>
                <div class="sk" style="height:14px;width:@(r % 3 == 0 ? "220px" : r % 3 == 1 ? "160px" : "190px")"></div>
                <div class="sk" style="height:28px;width:130px;border-radius:6px"></div>
                <div style="flex:1"></div>
                <div class="sk" style="height:14px;width:65px"></div>
                <div class="sk" style="width:28px;height:28px;border-radius:50%"></div>
            </div>
        }
    </MudPaper>
}
else if (_confirmed.Count > 0)
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudText Typo="Typo.subtitle1">
                @MonthSvc.Month.ToString("MMMM yyyy", CultureInfo.InvariantCulture) (@_filtered.Count)
            </MudText>
            @if (_isMonthClosed)
            {
                <MudTooltip Text="This month is closed and cannot be edited.">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Color="Color.Default" />
                </MudTooltip>
            }
        </MudStack>
        <MudSpacer />
        @if (_selected.Count > 0 && !_isMonthClosed)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.DeleteForever"
                       OnClick="DeleteSelectedAsync">
                Delete (@_selected.Count)
            </MudButton>
        }
    </MudStack>

    <MudTextField T="string"
                  Value="@_searchTerm"
                  ValueChanged="@OnSearchChanged"
                  Placeholder="Search transactions… (press Enter)"
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Clearable="true"
                  Class="mb-2" />

    @if (_filtered.Count > 0)
    {
        <MudTable T="Transaction" Items="_filtered" Dense="true" Hover="true" Elevation="1" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh Style="width:44px">
                    @if (!_isMonthClosed)
                    {
                        <MudCheckBox T="bool?"
                                     Value="@(_allSelected ? (bool?)true : _noneSelected ? (bool?)false : null)"
                                     ValueChanged="@(_ => ToggleSelectAll())"
                                     Size="Size.Small" />
                    }
                </MudTh>
                <MudTh>
                    <MudTableSortLabel InitialDirection="SortDirection.Descending"
                                       SortBy="new Func<Transaction, object>(t => t.Date.ToDateTime(TimeOnly.MinValue))">
                        Date
                    </MudTableSortLabel>
                </MudTh>
                <MudTh>Description</MudTh>
                <MudTh>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">
                        Account
                        @if (_accounts.Count > 0)
                        {
                            <MudMenu AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft" Dense>
                                <ActivatorContent>
                                    <MudIconButton Icon="@(_accountFilter.Count > 0 ? Icons.Material.Filled.FilterAlt : Icons.Material.Outlined.FilterAlt)"
                                                   Size="Size.Small"
                                                   Color="@(_accountFilter.Count > 0 ? Color.Primary : Color.Default)" />
                                </ActivatorContent>
                                <ChildContent>
                                    <div style="padding:4px 12px 8px;min-width:170px">
                                        @foreach (var acct in _accounts)
                                        {
                                            var a = acct;
                                            <div>
                                                <MudCheckBox T="bool"
                                                             Value="@_accountFilter.Contains(a.Id)"
                                                             ValueChanged="@(v => ToggleAccountFilter(a.Id, v))"
                                                             Size="Size.Small" Dense Label="@a.Name" />
                                            </div>
                                        }
                                        @if (_accountFilter.Count > 0)
                                        {
                                            <MudDivider Class="my-1" />
                                            <MudButton Size="Size.Small" FullWidth
                                                       OnClick="@(() => { _accountFilter.Clear(); ApplyFilter(); })">
                                                Clear filter
                                            </MudButton>
                                        }
                                    </div>
                                </ChildContent>
                            </MudMenu>
                        }
                    </MudStack>
                </MudTh>
                <MudTh>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">
                        <MudTableSortLabel SortBy="new Func<Transaction, object>(t => t.Category ?? string.Empty)">
                            Category
                        </MudTableSortLabel>
                        <MudMenu AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft" Dense="true">
                            <ActivatorContent>
                                <MudIconButton Icon="@(_categoryFilter.Count > 0 ? Icons.Material.Filled.FilterAlt : Icons.Material.Outlined.FilterAlt)"
                                               Size="Size.Small"
                                               Color="@(_categoryFilter.Count > 0 ? Color.Primary : Color.Default)" />
                            </ActivatorContent>
                            <ChildContent>
                                <div style="padding:4px 12px 8px;min-width:170px;max-height:260px;overflow-y:auto">
                                    @foreach (var name in CategoryFilterOptions)
                                    {
                                        var n = name;
                                        <div>
                                            <MudCheckBox T="bool"
                                                         Value="@_categoryFilter.Contains(n)"
                                                         ValueChanged="@(v => ToggleCategoryFilter(n, v))"
                                                         Size="Size.Small" Dense="true" Label="@n" />
                                        </div>
                                    }
                                    @if (_categoryFilter.Count > 0)
                                    {
                                        <MudDivider Class="my-1" />
                                        <MudButton Size="Size.Small" FullWidth="true"
                                                   OnClick="@(() => { _categoryFilter.Clear(); SaveState(); UpdateUrl(); ApplyFilter(); })">
                                            Clear filter
                                        </MudButton>
                                    }
                                </div>
                            </ChildContent>
                        </MudMenu>
                    </MudStack>
                </MudTh>
                @if (_goals.Count > 0)
                {
                    <MudTh>Goal</MudTh>
                }
                <MudTh Style="text-align:right">
                    <MudTableSortLabel SortBy="new Func<Transaction, object>(t => t.Amount)">
                        Amount
                    </MudTableSortLabel>
                </MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    @if (!_isMonthClosed)
                    {
                        <MudCheckBox T="bool"
                                     Value="@_selected.Contains(context.Id)"
                                     ValueChanged="@(_ => ToggleSelect(context))"
                                     Size="Size.Small" />
                    }
                </MudTd>
                <MudTd DataLabel="Date">@context.Date.ToString("MMM d, yyyy")</MudTd>
                <MudTd DataLabel="Description">@context.Description</MudTd>
                <MudTd DataLabel="Account">
                    <MudSelect T="string" Value="@(context.AccountId?.ToString() ?? "")"
                               ValueChanged="@(async v => await UpdateAccountAsync(context, string.IsNullOrEmpty(v) ? null : Guid.Parse(v)))"
                               Dense="true" Variant="Variant.Outlined" Margin="Margin.Dense"
                               Placeholder="—" Class="cat-select" Style="min-width:120px"
                               Disabled="@(_isMonthClosed || _accounts.Count == 0)">
                        <MudSelectItem T="string" Value="@("")">—</MudSelectItem>
                        @foreach (var a in _accounts)
                        {
                            <MudSelectItem T="string" Value="@a.Id.ToString()">@a.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudTd>
                <MudTd DataLabel="Category">
                    @if (_isMonthClosed)
                    {
                        <MudText Typo="Typo.body2">@(context.Category ?? "—")</MudText>
                    }
                    else if (context.IsRevenue)
                    {
                        <MudSelect T="string" Value="@context.Category"
                                   ValueChanged="@(async v => await UpdateCategoryAsync(context, v))"
                                   Dense="true" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   Placeholder="—" Class="cat-select" Style="min-width:120px">
                            <MudSelectItem T="string" Value="@((string?)null)">—</MudSelectItem>
                            @foreach (var cat in _revenueCategories.OrderBy(c => c.Name))
                            {
                                <MudSelectItem T="string" Value="@cat.Name">@cat.Name</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else if (context.Amount >= 0)
                    {
                        <MudSelect T="string" Value="@context.Category"
                                   ValueChanged="@(async v => await UpdateCategoryAsync(context, v))"
                                   Dense="true" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   Placeholder="Unclassified" Class="cat-select" Style="min-width:120px">
                            <MudSelectItem T="string" Value="@((string?)null)">Unclassified</MudSelectItem>
                            @foreach (var cat in _categories.OrderBy(c => c.Name))
                            {
                                <MudSelectItem T="string" Value="@cat.Name">@cat.Name</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Color="Color.Default">—</MudText>
                    }
                </MudTd>
                @if (_goals.Count > 0)
                {
                    <MudTd DataLabel="Goal">
                        <MudSelect T="string" Value="@(context.GoalId?.ToString() ?? "")"
                                   ValueChanged="@(async v => await UpdateGoalAsync(context, string.IsNullOrEmpty(v) ? null : Guid.Parse(v)))"
                                   Dense="true" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   Placeholder="—" Class="cat-select" Style="min-width:110px"
                                   Disabled="@_isMonthClosed">
                            <MudSelectItem T="string" Value="@("")">—</MudSelectItem>
                            @foreach (var goal in _goals)
                            {
                                <MudSelectItem T="string" Value="@goal.Id.ToString()">@goal.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudTd>
                }
                <MudTd DataLabel="Amount" Style="text-align:right">
                    <MudText Color="@AmountColor(context.Amount)">@FormatAmount(context.Amount)</MudText>
                </MudTd>
                <MudTd>
                    @if (!_isMonthClosed)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Size="Size.Small" Color="Color.Error"
                                       OnClick="() => DeleteAsync(context)" />
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
    else
    {
        <MudAlert Severity="Severity.Info">
            No transactions in @MonthSvc.Month.ToString("MMMM yyyy", CultureInfo.InvariantCulture)@(_categoryFilter.Any() || !string.IsNullOrWhiteSpace(_searchTerm) ? " matching the current filters" : "").
        </MudAlert>
    }
}
else
{
    <MudAlert Severity="Severity.Info">
        No transactions yet. Click Import to get started.
    </MudAlert>
}

