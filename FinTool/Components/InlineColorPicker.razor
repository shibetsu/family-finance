<div style="position:relative;display:inline-block;flex-shrink:0">
    <div @onclick="@(() => _open = !_open)"
         style="width:22px;height:22px;border-radius:50%;background:@Value;cursor:pointer;
                border:1px solid rgba(0,0,0,.12);flex-shrink:0">
    </div>

    @if (_open)
    {
        <div @onclick="@(() => _open = false)"
             style="position:fixed;inset:0;z-index:998">
        </div>
        <div @onclick:stopPropagation="true"
             style="position:absolute;z-index:999;top:28px;left:0;
                    background:var(--mud-palette-surface);padding:12px;
                    border-radius:10px;border:1px solid var(--mud-palette-divider);
                    box-shadow:0 4px 24px rgba(0,0,0,.18);white-space:nowrap">
            <ColorPicker Value="@Value" ValueChanged="@OnColorSelected" />
        </div>
    }
</div>

@code {
    [Parameter] public string Value { get; set; } = "#594AE2";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    private bool _open;

    private async Task OnColorSelected(string color)
    {
        _open = false;
        await ValueChanged.InvokeAsync(color);
    }
}
