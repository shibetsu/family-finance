@inject NavigationManager Nav

@code {
    // Re-use the auth state already resolved by CascadingAuthenticationState / AuthorizeRouteView
    // instead of calling GetAuthenticationStateAsync() again (which makes extra JS interop + HTTP calls).
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Navigate after the render cycle so Blazor doesn't throw from inside a lifecycle method.
        var state = AuthState is not null ? await AuthState : null;
        var target = state?.User.Identity?.IsAuthenticated == true ? "/" : "/login";
        Nav.NavigateTo(target, replace: true);
    }
}
