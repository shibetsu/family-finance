@inject TransactionService TxSvc
@inject BudgetService BudgetSvc
@inject RevenueCategoryService RevenueSvc
@inject NavigationManager Nav
@inject MonthState MonthSvc
@implements IDisposable
@using System.Globalization

<MudText Typo="Typo.h5" Class="mb-6">Dashboard</MudText>

@if (_loading)
{
    <LoadingOverlay />
    <!-- 4 stat card skeletons -->
    <MudGrid Class="mb-4">
        @for (var i = 0; i < 4; i++)
        {
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="1" Class="pa-4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                        <div class="sk" style="width:38px;height:38px;border-radius:50%;flex-shrink:0"></div>
                        <div style="flex:1;min-width:0">
                            <div class="sk" style="height:11px;width:65%;margin-bottom:8px"></div>
                            <div class="sk" style="height:20px;width:50%"></div>
                        </div>
                    </MudStack>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
    <!-- 2 revenue/net card skeletons -->
    <MudGrid Class="mb-6">
        @for (var i = 0; i < 2; i++)
        {
            <MudItem xs="12" sm="6">
                <MudPaper Elevation="1" Class="pa-4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                        <div class="sk" style="width:38px;height:38px;border-radius:50%;flex-shrink:0"></div>
                        <div style="flex:1;min-width:0">
                            <div class="sk" style="height:11px;width:55%;margin-bottom:8px"></div>
                            <div class="sk" style="height:20px;width:42%"></div>
                        </div>
                    </MudStack>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
    <!-- 2 chart panel skeletons -->
    <MudGrid Class="mb-6">
        @for (var i = 0; i < 2; i++)
        {
            <MudItem xs="12" md="6">
                <MudPaper Elevation="1" Class="pa-4">
                    <div class="sk" style="height:15px;width:55%;margin-bottom:16px"></div>
                    <div class="sk" style="height:280px;border-radius:8px"></div>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
    <!-- Expense breakdown table skeleton -->
    <div class="sk" style="height:15px;width:165px;margin-bottom:12px"></div>
    <MudPaper Elevation="1" Class="overflow-hidden">
        <div style="display:flex;gap:12px;padding:13px 16px;border-bottom:1px solid var(--mud-palette-table-lines)">
            <div class="sk" style="height:13px;width:110px"></div>
            <div style="flex:1"></div>
            @for (var c = 0; c < 5; c++) { <div class="sk" style="height:13px;width:58px"></div> }
            <div class="sk" style="height:13px;width:120px"></div>
        </div>
        @for (var r = 0; r < 6; r++)
        {
            <div style="display:flex;align-items:center;gap:12px;padding:11px 16px;border-bottom:1px solid var(--mud-palette-table-lines)">
                <div style="display:flex;align-items:center;gap:8px;min-width:110px">
                    <div class="sk" style="width:12px;height:12px;border-radius:50%;flex-shrink:0"></div>
                    <div class="sk" style="height:14px;width:80px"></div>
                </div>
                <div style="flex:1"></div>
                @for (var c = 0; c < 4; c++) { <div class="sk" style="height:14px;width:58px"></div> }
                <div class="sk" style="height:14px;width:25px"></div>
                <div style="display:flex;align-items:center;gap:6px;min-width:120px">
                    <div class="sk" style="height:8px;flex:1;border-radius:4px"></div>
                    <div class="sk" style="height:12px;width:30px"></div>
                </div>
            </div>
        }
    </MudPaper>
}
else if (_categories.Count == 0 && !_hasData)
{
    <MudAlert Severity="Severity.Info">
        Add budget categories and import transactions to see your dashboard.
    </MudAlert>
}
else
{
    <!-- ── Row 1: Expense summary cards ────────────────────────────────── -->
    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="1" Class="pa-4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet"
                             Color="Color.Primary" Size="Size.Large" />
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Monthly Budget</MudText>
                        <MudText Typo="Typo.h6">@Fmt(_totalBudget)</MudText>
                    </div>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="1" Class="pa-4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    <MudIcon Icon="@Icons.Material.Filled.ShoppingCart"
                             Color="@(_totalSpent > _totalBudget && _totalBudget > 0 ? Color.Error : Color.Default)"
                             Size="Size.Large" />
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Spent</MudText>
                        <MudText Typo="Typo.h6">@Fmt(_totalSpent)</MudText>
                    </div>
                </MudStack>
            </MudPaper>
        </MudItem>
        @{ var budgetRem = _totalBudget - _totalSpent; }
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="1" Class="pa-4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    <MudIcon Icon="@(budgetRem >= 0 ? Icons.Material.Filled.Savings : Icons.Material.Filled.TrendingDown)"
                             Color="@(budgetRem >= 0 ? Color.Success : Color.Error)"
                             Size="Size.Large" />
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @(budgetRem >= 0 ? "Remaining" : "Over Budget")
                        </MudText>
                        <MudText Typo="Typo.h6" Color="@(budgetRem >= 0 ? Color.Success : Color.Error)">
                            @Fmt(Math.Abs(budgetRem))
                        </MudText>
                    </div>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="1" Class="pa-4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    <MudIcon Icon="@Icons.Material.Filled.Receipt"
                             Color="Color.Secondary" Size="Size.Large" />
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Transactions</MudText>
                        <MudText Typo="Typo.h6">@_txCount</MudText>
                    </div>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <!-- ── Row 2: Revenue + Net cards ──────────────────────────────────── -->
    <MudGrid Class="mb-6">
        <MudItem xs="12" sm="6">
            <MudPaper Elevation="1" Class="pa-4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    <MudIcon Icon="@Icons.Material.Filled.TrendingUp"
                             Color="Color.Success" Size="Size.Large" />
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Revenue</MudText>
                        <MudText Typo="Typo.h6" Color="Color.Success">@Fmt(_totalRevenue)</MudText>
                    </div>
                </MudStack>
            </MudPaper>
        </MudItem>
        @{ var net = _totalRevenue - _totalSpent; }
        <MudItem xs="12" sm="6">
            <MudPaper Elevation="1" Class="pa-4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    <MudIcon Icon="@(net >= 0 ? Icons.Material.Filled.AccountBalance : Icons.Material.Filled.Warning)"
                             Color="@(net >= 0 ? Color.Success : Color.Error)"
                             Size="Size.Large" />
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Net (Revenue − Expenses)
                        </MudText>
                        <MudText Typo="Typo.h6" Color="@(net >= 0 ? Color.Success : Color.Error)">
                            @(net >= 0 ? Fmt(net) : $"−{Fmt(-net)}")
                        </MudText>
                    </div>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @if (!_hasData)
    {
        <MudAlert Severity="Severity.Info">
            No transactions for @MonthSvc.Month.ToString("MMMM yyyy", CultureInfo.InvariantCulture).
        </MudAlert>
    }
    else
    {
        <!-- ── Donut + Trend ──────────────────────────────────────────── -->
        <MudGrid Class="mb-6">
            <MudItem xs="12" md="6">
                <MudPaper Elevation="1" Class="pa-4" Style="height: 100%">
                    <MudText Typo="Typo.subtitle1" Class="mb-1">Spending by Category</MudText>
                    @if (_donutData.Length > 0)
                    {
                        <div style="position: relative;">
                            <MudChart ChartType="ChartType.Donut"
                                      InputData="@_donutData"
                                      InputLabels="@_donutLabels"
                                      ChartOptions="@_donutOptions"
                                      @bind-SelectedIndex="_selectedDonutIndex"
                                      Width="100%" Height="280px" />
                            <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;max-width:120px;cursor:pointer"
                                 @onclick="@(() => GoToCategory(_donutLabels[_selectedDonutIndex]))"
                                 title="View transactions for @_donutLabels[_selectedDonutIndex]">
                                <div style="font-size:1.1rem;font-weight:600;line-height:1.3">
                                    @Fmt((decimal)_donutData[_selectedDonutIndex])
                                </div>
                                <div style="font-size:0.75rem;opacity:0.7;line-height:1.3;word-break:break-word">
                                    @_donutLabels[_selectedDonutIndex]
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <MudText Color="Color.Secondary" Class="mt-4">No categorized spending this month.</MudText>
                    }
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Elevation="1" Class="pa-4" Style="height: 100%">
                    <MudText Typo="Typo.subtitle1" Class="mb-1">6-Month Trend</MudText>
                    <MudChart ChartType="ChartType.Line"
                              ChartSeries="@_trendSeries"
                              XAxisLabels="@_trendLabels"
                              ChartOptions="@_trendOptions"
                              Width="100%" Height="280px" />
                </MudPaper>
            </MudItem>
        </MudGrid>

        <!-- ── Expense category breakdown ─────────────────────────────── -->
        <MudText Typo="Typo.subtitle1" Class="mb-2">Expense Breakdown</MudText>
        <MudTable T="CatRow" Items="_categoryRows" Dense="true" Hover="true" Elevation="1" Class="mb-6" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh>Category</MudTh>
                <MudTh Style="text-align:right">Budget</MudTh>
                <MudTh Style="text-align:right">Spent</MudTh>
                <MudTh Style="text-align:right">Remaining</MudTh>
                <MudTh Style="text-align:right">Txns</MudTh>
                <MudTh Style="text-align:right">Avg / Txn</MudTh>
                <MudTh Style="min-width:140px">Usage</MudTh>
            </HeaderContent>
            <RowTemplate>
                @{
                    var rowRem   = context.Budget - context.Spent;
                    var pct      = context.Budget > 0 ? (int)Math.Min(100, context.Spent / context.Budget * 100) : 0;
                    var barColor = pct >= 100 ? Color.Error : pct >= 80 ? Color.Warning : Color.Success;
                }
                <MudTd DataLabel="Category">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Circle"
                                 Style="@($"color:{context.Color}")" Size="Size.Small" />
                        <MudLink OnClick="@(() => GoToCategory(context.Name))"
                                 Underline="Underline.Hover" Color="Color.Inherit"
                                 Style="cursor:pointer">@context.Name</MudLink>
                    </MudStack>
                </MudTd>
                <MudTd DataLabel="Budget" Style="text-align:right">@Fmt(context.Budget)</MudTd>
                <MudTd DataLabel="Spent" Style="text-align:right">
                    <MudText Color="@(context.Spent > context.Budget && context.Budget > 0 ? Color.Error : Color.Default)">
                        @Fmt(context.Spent)
                    </MudText>
                </MudTd>
                <MudTd DataLabel="Remaining" Style="text-align:right">
                    <MudText Color="@(rowRem >= 0 ? Color.Success : Color.Error)">
                        @(rowRem >= 0 ? Fmt(rowRem) : $"−{Fmt(-rowRem)}")
                    </MudText>
                </MudTd>
                <MudTd DataLabel="Txns" Style="text-align:right">
                    <MudText Color="@(context.Count > 0 ? Color.Default : Color.Secondary)">
                        @context.Count
                    </MudText>
                </MudTd>
                <MudTd DataLabel="Avg / Txn" Style="text-align:right">
                    @if (context.Count > 0)
                    {
                        @Fmt(context.Avg)
                    }
                </MudTd>
                <MudTd DataLabel="Usage">
                    @if (context.Budget > 0)
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudProgressLinear Value="@pct" Color="@barColor"
                                               Size="Size.Medium" Rounded="true"
                                               Style="flex:1" />
                            <MudText Typo="Typo.caption" Style="min-width:36px">@pct%</MudText>
                        </MudStack>
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>

        <!-- ── Revenue breakdown ──────────────────────────────────────── -->
        @if (_revenueRows.Count > 0)
        {
            <MudText Typo="Typo.subtitle1" Class="mb-2">Revenue Breakdown</MudText>
            <MudTable T="RevRow" Items="_revenueRows" Dense="true" Hover="true" Elevation="1" Class="mb-6" Breakpoint="Breakpoint.Sm">
                <HeaderContent>
                    <MudTh>Category</MudTh>
                    <MudTh Style="text-align:right">Amount</MudTh>
                    <MudTh Style="text-align:right">Txns</MudTh>
                    <MudTh Style="text-align:right">Avg / Txn</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Category">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Circle"
                                     Style="@($"color:{context.Color}")" Size="Size.Small" />
                            <MudLink OnClick="@(() => GoToCategory(context.Name))"
                                     Underline="Underline.Hover" Color="Color.Inherit"
                                     Style="cursor:pointer">@context.Name</MudLink>
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Amount" Style="text-align:right">
                        <MudText Color="Color.Success">@Fmt(context.Amount)</MudText>
                    </MudTd>
                    <MudTd DataLabel="Txns" Style="text-align:right">@context.Count</MudTd>
                    <MudTd DataLabel="Avg / Txn" Style="text-align:right">
                        @if (context.Count > 0)
                        {
                            <MudText Color="Color.Success">@Fmt(context.Avg)</MudText>
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }

        <!-- ── Ignored Transactions ───────────────────────────────────── -->
        @if (_ignoredTx.Count > 0)
        {
            <MudPaper Elevation="1" Class="pa-3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="cursor:pointer"
                          @onclick="@(() => _showIgnored = !_showIgnored)">
                    <MudIcon Icon="@Icons.Material.Filled.VisibilityOff"
                             Color="Color.Secondary" Size="Size.Small" />
                    <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
                        Ignored Transactions
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        (@_ignoredTx.Count)
                    </MudText>
                    <MudSpacer />
                    @if (_ignoredExpenseTotal > 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary"
                                 Style="border:1px solid var(--mud-palette-divider);border-radius:4px;padding:2px 8px">
                            −@Fmt(_ignoredExpenseTotal)
                        </MudText>
                    }
                    @if (_ignoredRevenueTotal > 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary"
                                 Style="border:1px solid var(--mud-palette-divider);border-radius:4px;padding:2px 8px">
                            +@Fmt(_ignoredRevenueTotal)
                        </MudText>
                    }
                    <MudIconButton Icon="@(_showIgnored ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                   Size="Size.Small" Color="Color.Secondary" />
                </MudStack>

                @if (_showIgnored)
                {
                    <MudDivider Class="my-2" />
                    <MudTable T="Transaction" Items="_ignoredTx" Dense="true" Hover="true"
                              Elevation="0" Style="opacity:0.8" Breakpoint="Breakpoint.Sm">
                        <HeaderContent>
                            <MudTh>Date</MudTh>
                            <MudTh>Description</MudTh>
                            <MudTh>Category</MudTh>
                            <MudTh Style="text-align:right">Amount</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            @{
                                var color = _categoryColorMap.GetValueOrDefault(context.Category ?? "", "#9E9E9E");
                            }
                            <MudTd DataLabel="Date">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @context.Date.ToString("MMM d", CultureInfo.InvariantCulture)
                                </MudText>
                            </MudTd>
                            <MudTd DataLabel="Description">
                                <MudText Typo="Typo.body2" Color="Color.Secondary"
                                         Style="max-width:320px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                                    @context.Description
                                </MudText>
                            </MudTd>
                            <MudTd DataLabel="Category">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.Circle"
                                             Style="@($"color:{color};opacity:0.6")" Size="Size.Small" />
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        @(context.Category ?? "—")
                                    </MudText>
                                </MudStack>
                            </MudTd>
                            <MudTd DataLabel="Amount" Style="text-align:right">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @(context.IsRevenue ? $"+{Fmt(-context.Amount)}" : Fmt(context.Amount))
                                </MudText>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>
        }
    }
}

