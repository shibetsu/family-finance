@using FinTool.Models

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form">
            <MudTextField @bind-Value="Goal.Name"
                          Label="Goal name"
                          Required="true"
                          RequiredError="Name is required."
                          Immediate="true"
                          Class="mb-3" />
            <MudNumericField T="decimal"
                             @bind-Value="Goal.TargetAmount"
                             Label="Target amount (CAD)"
                             Min="0.01m"
                             Format="F2"
                             Adornment="Adornment.Start"
                             AdornmentText="$"
                             Class="mb-3" />
            <MudNumericField T="decimal"
                             @bind-Value="Goal.CurrentAmount"
                             Label="Starting balance (CAD)"
                             Min="0"
                             Format="F2"
                             Adornment="Adornment.Start"
                             AdornmentText="$"
                             Class="mb-3" />
            <MudTextField @bind-Value="Goal.Notes"
                          Label="Notes (optional)"
                          Lines="2"
                          Class="mb-4" />

            <MudText Typo="Typo.caption" Class="mb-2">Colour</MudText>
            <ColorPicker @bind-Value="_color" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => MudDialog.Cancel()">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = default!;
    [Parameter]          public Goal Goal            { get; set; } = default!;

    private MudForm _form  = default!;
    private string  _color = ColorPalette.Random();

    protected override void OnParametersSet() => _color = Goal.Color;

    private async Task Submit()
    {
        await _form.Validate();
        if (_form.IsValid)
        {
            Goal.Color = _color;
            MudDialog.Close(DialogResult.Ok(true));
        }
    }
}
