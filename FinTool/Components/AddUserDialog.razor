<MudDialog>
    <DialogContent>
        <MudForm @ref="_form">
            <MudTextField @bind-Value="_username"
                          Label="Username"
                          Required="true"
                          RequiredError="Username is required."
                          Variant="Variant.Outlined"
                          Class="mb-3"
                          Immediate="true" />
            <MudTextField @bind-Value="_displayName"
                          Label="Display Name"
                          Variant="Variant.Outlined"
                          Class="mb-3"
                          Immediate="true" />
            <MudTextField @bind-Value="_email"
                          Label="Email"
                          Variant="Variant.Outlined"
                          Class="mb-3"
                          InputType="InputType.Email"
                          Immediate="true" />
            <MudSelect @bind-Value="_role"
                       Label="Role"
                       Variant="Variant.Outlined"
                       Class="mb-3">
                <MudSelectItem Value="@("User")">User</MudSelectItem>
                <MudSelectItem Value="@("Owner")">Owner</MudSelectItem>
            </MudSelect>
            <MudTextField @bind-Value="_password"
                          Label="Password"
                          Required="true"
                          RequiredError="Password is required."
                          Variant="Variant.Outlined"
                          InputType="@(_showPwd ? InputType.Text : InputType.Password)"
                          Adornment="Adornment.End"
                          AdornmentIcon="@(_showPwd ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                          OnAdornmentClick="() => _showPwd = !_showPwd"
                          Immediate="true" />
        </MudForm>
        @if (!string.IsNullOrEmpty(_error))
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mt-3">@_error</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => MudDialog.Cancel()">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="SubmitAsync" Disabled="@_saving">
            @(_saving ? "Creating…" : "Create")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = default!;

    [Inject] AuthService Auth { get; set; } = default!;

    private MudForm _form     = default!;
    private string  _username    = "";
    private string  _displayName = "";
    private string  _email       = "";
    private string  _role        = "User";
    private string  _password    = "";
    private string  _error    = "";
    private bool    _saving   = false;
    private bool    _showPwd  = false;

    private async Task SubmitAsync()
    {
        await _form.Validate();
        if (!_form.IsValid) return;
        _error  = "";
        _saving = true;
        var ok = await Auth.RegisterAsync(_username, _password,
            string.IsNullOrWhiteSpace(_email)       ? null : _email,
            string.IsNullOrWhiteSpace(_displayName) ? null : _displayName,
            _role);
        _saving = false;
        if (ok)
            MudDialog.Close(DialogResult.Ok(true));
        else
            _error = "Username already exists or an error occurred.";
    }
}
