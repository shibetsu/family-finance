<MudDialog>
    <DialogContent>
        @if (_done)
        {
            @if (_warning != null)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">@_warning</MudAlert>
            }
            else
            {
                <MudAlert Severity="Severity.Success" Dense="true" Class="mb-3">
                    Invitation email sent to <strong>@_email</strong>.
                </MudAlert>
            }
            @if (_setPasswordUrl != null)
            {
                <MudText Typo="Typo.body2" Class="mb-1" Style="word-break:break-all;font-size:0.8rem;color:var(--mud-palette-text-secondary)">
                    @_setPasswordUrl
                </MudText>
                <MudButton Variant="Variant.Outlined"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.ContentCopy"
                           OnClick="CopyUrlAsync">
                    @(_copied ? "Copied!" : "Copy link")
                </MudButton>
            }
        }
        else
        {
            <MudForm @ref="_form">
                <MudTextField @bind-Value="_username"
                              Label="Username"
                              Required="true"
                              RequiredError="Username is required."
                              Variant="Variant.Outlined"
                              Class="mb-3"
                              Immediate="true" />
                <MudTextField @bind-Value="_displayName"
                              Label="Display Name"
                              Variant="Variant.Outlined"
                              Class="mb-3"
                              Immediate="true" />
                <MudTextField @bind-Value="_email"
                              Label="Email"
                              Required="true"
                              RequiredError="Email is required to send the setup link."
                              Variant="Variant.Outlined"
                              Class="mb-3"
                              InputType="InputType.Email"
                              Immediate="true" />
                <MudSelect @bind-Value="_role"
                           Label="Role"
                           Variant="Variant.Outlined"
                           Class="mb-0">
                    <MudSelectItem Value="@("User")">User</MudSelectItem>
                    <MudSelectItem Value="@("Owner")">Owner</MudSelectItem>
                </MudSelect>
            </MudForm>
            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mt-3">@_error</MudAlert>
            }
        }
    </DialogContent>
    <DialogActions>
        @if (_done)
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled"
                       OnClick="() => MudDialog.Close(DialogResult.Ok(true))">
                Done
            </MudButton>
        }
        else
        {
            <MudButton OnClick="() => MudDialog.Cancel()">Cancel</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled"
                       OnClick="SubmitAsync" Disabled="@_saving">
                @(_saving ? "Creating…" : "Create")
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@inject IJSRuntime JS

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = default!;

    [Inject] AuthService Auth { get; set; } = default!;

    private MudForm _form        = default!;
    private string  _username    = "";
    private string  _displayName = "";
    private string  _email       = "";
    private string  _role        = "User";
    private string  _error       = "";
    private bool    _saving      = false;
    private bool    _done        = false;
    private bool    _copied      = false;
    private string? _warning;
    private string? _setPasswordUrl;

    private async Task SubmitAsync()
    {
        await _form.Validate();
        if (!_form.IsValid) return;
        _error  = "";
        _saving = true;
        var result = await Auth.RegisterAsync(_username,
            string.IsNullOrWhiteSpace(_email)       ? null : _email,
            string.IsNullOrWhiteSpace(_displayName) ? null : _displayName,
            _role);
        _saving = false;
        if (!result.Ok)
        {
            _error = result.Error ?? "An error occurred.";
            return;
        }
        _warning        = result.Warning;
        _setPasswordUrl = result.SetPasswordUrl;
        _done           = true;
    }

    private async Task CopyUrlAsync()
    {
        if (_setPasswordUrl is null) return;
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", _setPasswordUrl);
        _copied = true;
        StateHasChanged();
    }
}
