@inject RevenueCategoryService RevenueSvc
@inject IDialogService DialogSvc

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5">Revenue</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="AddCategory">
        Add Category
    </MudButton>
</MudStack>

@if (_loading)
{
    <LoadingOverlay />
    <MudPaper Elevation="1" Class="overflow-hidden">
        <div style="display:flex;gap:12px;padding:13px 16px;border-bottom:1px solid var(--mud-palette-table-lines)">
            <div class="sk" style="height:13px;width:130px"></div>
            <div style="flex:1"></div>
            <div class="sk" style="height:13px;width:70px"></div>
        </div>
        @for (var r = 0; r < 5; r++)
        {
            <div style="display:flex;align-items:center;gap:12px;padding:14px 16px;border-bottom:1px solid var(--mud-palette-table-lines)">
                <div style="display:flex;align-items:center;gap:8px;flex:1;min-width:0">
                    <div class="sk" style="width:12px;height:12px;border-radius:50%;flex-shrink:0"></div>
                    <div class="sk" style="height:14px;width:@(r % 3 == 0 ? "100px" : r % 3 == 1 ? "80px" : "120px")"></div>
                </div>
                <div style="display:flex;gap:4px">
                    <div class="sk" style="width:28px;height:28px;border-radius:50%"></div>
                    <div class="sk" style="width:28px;height:28px;border-radius:50%"></div>
                </div>
            </div>
        }
    </MudPaper>
}
else if (_categories.Count == 0)
{
    <MudAlert Severity="Severity.Info" Class="mt-2">
        No revenue categories yet. Add categories like Salary, Freelance, or Investments.
    </MudAlert>
}
else
{
    <MudTable T="RevenueCategory" Items="_categories" Hover="true" Elevation="1">
        <HeaderContent>
            <MudTh>Category</MudTh>
            <MudTh Style="text-align:right">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Category">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2"
                          Style="@(context.IsIgnored ? "opacity:0.45" : "")">
                    <MudIcon Icon="@Icons.Material.Filled.Circle"
                             Style="@($"color:{context.Color}")" Size="Size.Small" />
                    <MudText>@context.Name</MudText>
                    @if (context.IsIgnored)
                    {
                        <MudTooltip Text="Excluded from dashboard and totals">
                            <MudIcon Icon="@Icons.Material.Filled.VisibilityOff"
                                     Size="Size.Small" Color="Color.Default" />
                        </MudTooltip>
                    }
                </MudStack>
            </MudTd>
            <MudTd Style="text-align:right">
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                               Size="Size.Small"
                               OnClick="() => EditCategory(context)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                               Size="Size.Small" Color="Color.Error"
                               OnClick="() => DeleteCategory(context)" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<RevenueCategory> _categories = [];
    private bool _loading = true;

    private static readonly DialogOptions _dialogOptions =
        new() { MaxWidth = MaxWidth.Small, FullWidth = true };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Task.Delay(1);
        _categories = await RevenueSvc.GetCategoriesAsync();
        _loading = false;
        StateHasChanged();
    }

    private async Task AddCategory()
    {
        var category = new RevenueCategory { Color = ColorPalette.Random() };
        var parameters = new DialogParameters<RevenueCategoryDialog> { { x => x.Category, category } };
        var dialog = await DialogSvc.ShowAsync<RevenueCategoryDialog>(
            "Add Revenue Category", parameters, _dialogOptions);
        if (!(await dialog.Result)!.Canceled)
        {
            await RevenueSvc.SaveAsync(category);
            _categories = await RevenueSvc.GetCategoriesAsync();
        }
    }

    private async Task EditCategory(RevenueCategory original)
    {
        var copy = new RevenueCategory
        {
            Id        = original.Id,
            Name      = original.Name,
            Color     = original.Color,
            IsIgnored = original.IsIgnored
        };
        var parameters = new DialogParameters<RevenueCategoryDialog> { { x => x.Category, copy } };
        var dialog = await DialogSvc.ShowAsync<RevenueCategoryDialog>(
            "Edit Revenue Category", parameters, _dialogOptions);
        if (!(await dialog.Result)!.Canceled)
        {
            await RevenueSvc.SaveAsync(copy);
            _categories = await RevenueSvc.GetCategoriesAsync();
        }
    }

    private async Task DeleteCategory(RevenueCategory category)
    {
        var confirmed = await DialogSvc.ShowMessageBox(
            "Delete Category",
            $"Delete \"{category.Name}\"? This cannot be undone.",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed == true)
        {
            await RevenueSvc.DeleteAsync(category.Id);
            _categories = await RevenueSvc.GetCategoriesAsync();
        }
    }
}
