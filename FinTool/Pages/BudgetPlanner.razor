@page "/budget-planner"
@attribute [Authorize]
@inject TransactionService TxSvc
@inject BudgetService BudgetSvc
@inject RevenueCategoryService RevenueSvc
@inject BudgetPlannerService PlannerSvc
@inject IDialogService DialogSvc
@inject ISnackbar Snackbar
@using System.Globalization
@using FinTool.Models
@using FinTool.Services

<PageTitle>Planner – FinTool</PageTitle>

@if (_loading)
{
    <LoadingOverlay />
}
else
{
    <!-- ── Header ───────────────────────────────────────────────────────── -->
    <MudStack Row="true" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Class="mb-5" Spacing="2">
        <MudText Typo="Typo.h5">Planner</MudText>
        <MudSpacer />
        @if (_importOptions.Count > 0)
        {
            <MudMenu StartIcon="@Icons.Material.Filled.FileDownload" Label="Import history"
                     Variant="Variant.Outlined" Size="Size.Small" AnchorOrigin="Origin.BottomRight"
                     TransformOrigin="Origin.TopRight">
                @foreach (var opt in _importOptions)
                {
                    var o = opt;
                    <MudMenuItem OnClick="@(() => ImportAsync(o.Months, o.Label))">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                            <div>
                                <MudText Typo="Typo.body2">@o.Label</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @(o.Months == 1 ? "1 month" : $"Average of {o.Months} months")
                                </MudText>
                            </div>
                        </MudStack>
                    </MudMenuItem>
                }
            </MudMenu>
        }
        @if (_drafts.Count > 0)
        {
            <MudButton StartIcon="@Icons.Material.Filled.PublishedWithChanges"
                       Variant="Variant.Outlined" Size="Size.Small"
                       OnClick="ApplyToSettingsAsync">
                Apply to Settings
            </MudButton>
        }
        <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled"
                   Color="Color.Primary" Size="Size.Small" OnClick="AddDraft">
            New Draft
        </MudButton>
    </MudStack>

    @if (_drafts.Count == 0)
    {
        <!-- ── Empty state ──────────────────────────────────────────────── -->
        <MudPaper Elevation="0" Class="pa-10" Style="text-align:center;border:2px dashed var(--mud-palette-divider);border-radius:12px">
            <MudIcon Icon="@Icons.Material.Filled.Savings" Style="font-size:3rem;opacity:0.3" Class="mb-3" />
            <MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mb-1">No drafts yet</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                Start from scratch or pull in your actual spending as a baseline.
            </MudText>
            <MudStack Row="true" Justify="Justify.Center" Spacing="2">
                @if (_importOptions.Count > 0)
                {
                    <MudButton StartIcon="@Icons.Material.Filled.FileDownload"
                               Variant="Variant.Outlined"
                               OnClick="@(() => ImportAsync(_importOptions[^1].Months, _importOptions[^1].Label))">
                        Import last @(_importOptions[^1].Months == 1 ? "month" : $"{_importOptions[^1].Months} months")
                    </MudButton>
                }
                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled"
                           Color="Color.Primary" OnClick="AddDraft">
                    New blank draft
                </MudButton>
            </MudStack>
        </MudPaper>
    }
    else
    {
        <!-- ── Draft tab bar ────────────────────────────────────────────── -->
        <div style="display:flex;align-items:center;gap:4px;overflow-x:auto;padding-bottom:2px;margin-bottom:16px">
            @for (var i = 0; i < _drafts.Count; i++)
            {
                var idx = i;
                var active = idx == _activeIdx;
                <div @onclick="@(() => _activeIdx = idx)"
                     style="@TabStyle(active)">
                    <input value="@_drafts[idx].Name"
                           @onchange="@(async e => { _drafts[idx].Name = e.Value?.ToString() ?? _drafts[idx].Name; await SaveAsync(); })"
                           @onclick:stopPropagation="true"
                           style="@InputStyle(active, _drafts[idx].Name.Length)" />
                    <button type="button"
                            @onclick="@(async () => await DeleteDraftAsync(idx))"
                            @onclick:stopPropagation="true"
                            style="background:none;border:none;padding:0;cursor:pointer;display:flex;align-items:center;color:inherit;opacity:0.55;flex-shrink:0;border-radius:4px">
                        <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
                    </button>
                </div>
            }
        </div>

        <!-- ── Summary cards ────────────────────────────────────────────── -->
        <MudGrid Class="mb-6">
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="1" Class="pa-4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                        <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet"
                                 Color="Color.Primary" Size="Size.Large" />
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Monthly Budget</MudText>
                            <MudText Typo="Typo.h6">@Fmt(TotalExpense)</MudText>
                        </div>
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="1" Class="pa-4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                        <MudIcon Icon="@Icons.Material.Filled.TrendingUp"
                                 Color="Color.Success" Size="Size.Large" />
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Monthly Revenue</MudText>
                            <MudText Typo="Typo.h6" Color="Color.Success">@Fmt(TotalRevenue)</MudText>
                        </div>
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="1" Class="pa-4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                        <MudIcon Icon="@(Net >= 0 ? Icons.Material.Filled.AccountBalance : Icons.Material.Filled.Warning)"
                                 Color="@(Net >= 0 ? Color.Success : Color.Error)" Size="Size.Large" />
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Net</MudText>
                            <MudText Typo="Typo.h6" Color="@(Net >= 0 ? Color.Success : Color.Error)">
                                @(Net >= 0 ? Fmt(Net) : $"−{Fmt(-Net)}")
                            </MudText>
                        </div>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <!-- ── Expense + Revenue tables ─────────────────────────────────── -->
        <MudGrid>
            <MudItem xs="12" md="6">
                @DrawTable(ActiveDraft, isRevenue: false)
            </MudItem>
            <MudItem xs="12" md="6">
                @DrawTable(ActiveDraft, isRevenue: true)
            </MudItem>
        </MudGrid>

        <!-- ── Notes ────────────────────────────────────────────────────── -->
        <MudPaper Elevation="1" Class="pa-4 mt-4">
            <MudText Typo="Typo.subtitle1" Class="mb-3">Notes</MudText>
            <MudTextField T="string"
                          Value="@ActiveDraft.Notes"
                          ValueChanged="@(async v => { ActiveDraft.Notes = v ?? ""; await SaveAsync(); })"
                          Placeholder="Add notes, assumptions, or reminders for this draft…"
                          Lines="5"
                          Variant="Variant.Outlined"
                          FullWidth="true" />
        </MudPaper>
    }
}

<ChatBot Context="ChatBotContext.BudgetPlanner" OnDraftReady="OnAiDraftCreated" />

@code {
    // DrawTable stays here because it embeds Razor HTML syntax; all other members are in BudgetPlanner.razor.cs

    private RenderFragment DrawTable(BudgetDraft draft, bool isRevenue) => __builder =>
    {
        var rows     = isRevenue ? draft.Revenue : draft.Expenses;
        var hist     = isRevenue ? _histRevenue : _histExpense;
        var title    = isRevenue ? "Revenue" : "Expenses";
        var hasHist  = hist.Count > 0;
        var gridCols = hasHist ? "28px 1fr 110px 80px 32px" : "28px 1fr 110px 32px";

        <MudPaper Elevation="1" Class="pa-4" Style="height:100%">
            <MudText Typo="Typo.subtitle1" Class="mb-3">@title</MudText>

            @if (rows.Count > 0)
            {
                <!-- Column headers -->
                <div style="display:grid;grid-template-columns:@gridCols;gap:6px;align-items:center;padding:0 0 6px;border-bottom:1px solid var(--mud-palette-divider);margin-bottom:4px">
                    <div></div>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Category</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="text-align:right">Monthly</MudText>
                    @if (hasHist)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="text-align:right">Hist. avg</MudText>
                    }
                    <div></div>
                </div>

                @foreach (var row in rows)
                {
                    var r = row;
                    var histAmt = hist.GetValueOrDefault(r.Name);
                    var diff = r.Amount - histAmt;

                    <div style="display:grid;grid-template-columns:@gridCols;gap:6px;align-items:center;padding:3px 0">
                        <!-- Color picker -->
                        <InlineColorPicker Value="@r.Color"
                                           ValueChanged="@(async v => { r.Color = v; await SaveAsync(); })" />

                        <!-- Name -->
                        <input value="@r.Name"
                               @onchange="@(async e => { r.Name = e.Value?.ToString() ?? r.Name; await SaveAsync(); })"
                               placeholder="Category name"
                               style="border:none;border-bottom:1px solid var(--mud-palette-divider);outline:none;background:transparent;font-size:0.875rem;color:inherit;width:100%;padding:2px 0" />

                        <!-- Amount -->
                        <MudNumericField T="decimal" Value="@r.Amount"
                                         ValueChanged="@(async v => { r.Amount = v; await SaveAsync(); })"
                                         Variant="Variant.Outlined" Margin="Margin.Dense"
                                         Format="N0" HideSpinButtons="true"
                                         Style="font-size:0.875rem" />

                        <!-- Historical avg -->
                        @if (hasHist)
                        {
                            <div style="text-align:right">
                                @if (histAmt > 0)
                                {
                                    <MudTooltip Text="@(diff >= 0 ? $"+{Fmt(diff)} vs historical avg" : $"−{Fmt(-diff)} vs historical avg")">
                                        <MudText Typo="Typo.caption"
                                                 Color="@(Math.Abs(diff) < histAmt * 0.05m ? Color.Secondary : diff > 0 ? Color.Warning : Color.Success)"
                                                 Style="cursor:default">
                                            ~@Fmt(histAmt)
                                        </MudText>
                                    </MudTooltip>
                                }
                                else
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="opacity:0.4">—</MudText>
                                }
                            </div>
                        }

                        <!-- Delete -->
                        <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small"
                                       Color="Color.Default"
                                       OnClick="@(async () => { rows.Remove(r); await SaveAsync(); })" />
                    </div>
                }
            }
            else
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3" Style="opacity:0.6">
                    No @title.ToLower() categories yet.
                </MudText>
            }

            <!-- Add row -->
            <MudButton StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" Variant="Variant.Text"
                       Color="Color.Default" Class="mt-2"
                       OnClick="@(async () => { rows.Add(new DraftRow { Color = ColorPalette.Random() }); await SaveAsync(); })">
                Add category
            </MudButton>
        </MudPaper>
    };
}
