@page "/settings/email"
@attribute [Authorize(Roles = "Owner")]
@inject EmailConfigService EmailCfg
@inject ISnackbar Snackbar

<PageTitle>Email Settings – FinTool</PageTitle>

<MudText Typo="Typo.h5" Class="mb-5">Email</MudText>

<MudGrid>
    <MudItem xs="12" md="8" lg="6">
        <MudPaper Elevation="1" Class="pa-5" Style="border-radius:12px">
            @if (_loading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4" Style="line-height:1.6">
                    Emails are sent directly to the recipient's mail server via MX record lookup — no relay needed.
                    Messages may land in spam without proper DNS records (SPF/DKIM/DMARC).
                </MudText>

                <MudGrid Spacing="3">
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_fromAddress"
                                      Label="From Address"
                                      Variant="Variant.Outlined"
                                      Placeholder="noreply@example.com"
                                      InputType="InputType.Email"
                                      Immediate="true" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_fromName"
                                      Label="From Name"
                                      Variant="Variant.Outlined"
                                      Immediate="true" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_appBaseUrl"
                                      Label="App Base URL"
                                      HelperText="Used in email links — must be reachable by recipients."
                                      Variant="Variant.Outlined"
                                      Immediate="true" />
                    </MudItem>
                </MudGrid>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Disabled="@_saving"
                           Class="mt-4"
                           OnClick="SaveAsync">
                    @(_saving ? "Saving…" : "Save")
                </MudButton>

                <MudDivider Class="my-5" />

                <MudText Typo="Typo.subtitle2" Class="mb-3">Send test email</MudText>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudTextField @bind-Value="_testTo"
                                  Label="Recipient address"
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Email"
                                  Immediate="true"
                                  Style="flex:1" />
                    <MudButton Variant="Variant.Outlined"
                               Disabled="@(_testing || string.IsNullOrWhiteSpace(_testTo))"
                               OnClick="SendTestAsync">
                        @(_testing ? "Sending…" : "Send")
                    </MudButton>
                </MudStack>
            }
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private bool   _loading     = true;
    private bool   _saving      = false;
    private bool   _testing     = false;
    private string _testTo      = "";
    private string _fromAddress = "";
    private string _fromName    = "Family Finance";
    private string _appBaseUrl  = "http://localhost:5111";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Task.Delay(1);
        var cfg = await EmailCfg.GetAsync();
        if (cfg != null)
        {
            _fromAddress = cfg.FromAddress;
            _fromName    = cfg.FromName;
            _appBaseUrl  = cfg.AppBaseUrl;
        }
        _loading = false;
        StateHasChanged();
    }

    private async Task SaveAsync()
    {
        _saving = true;
        var (ok, err) = await EmailCfg.SaveAsync(_fromAddress, _fromName, _appBaseUrl);
        _saving = false;
        Snackbar.Add(ok ? "Email settings saved." : err ?? "Failed to save.",
                     ok ? Severity.Success : Severity.Error);
        StateHasChanged();
    }

    private async Task SendTestAsync()
    {
        _testing = true;
        StateHasChanged();
        var (ok, err) = await EmailCfg.SendTestAsync(_testTo);
        _testing = false;
        if (ok)
            Snackbar.Add($"Test email sent to {_testTo}. Check your spam folder.", Severity.Success);
        else
            Snackbar.Add($"Test failed: {err}", Severity.Error);
        StateHasChanged();
    }
}
