@page "/set-password"
@attribute [AllowAnonymous]
@layout LoginLayout
@inject AuthService Auth
@inject NavigationManager Nav
@inject AppInfoService AppInfo

<PageTitle>Set Password – FinTool</PageTitle>

<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:#f5f5f5;position:relative">
    <MudPaper Elevation="2" Style="width:100%;max-width:400px;padding:40px 32px;border-radius:16px">
        <div style="text-align:center;margin-bottom:32px">
            <img src="fintool_preview.png" alt="logo"
                 style="height:52px;width:52px;display:block;margin:0 auto 14px" />
            <MudText Typo="Typo.h5" Style="font-weight:700;letter-spacing:-0.3px">Family Finance</MudText>
        </div>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else if (_tokenError != null)
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_tokenError</MudAlert>
            <MudButton Variant="Variant.Outlined" FullWidth="true" OnClick='() => Nav.NavigateTo("/login")'>
                Back to sign in
            </MudButton>
        }
        else if (_success)
        {
            <MudAlert Severity="Severity.Success" Class="mb-4">
                Password set successfully. You can now sign in.
            </MudAlert>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                       OnClick='() => Nav.NavigateTo("/login")'>
                Sign in
            </MudButton>
        }
        else
        {
            <MudText Typo="Typo.body1" Class="mb-1" Style="font-weight:600">
                Hello, @(_displayName ?? _username)!
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                Choose a password for your account (@_username).
            </MudText>

            <MudTextField @bind-Value="_password"
                          Label="New password"
                          Variant="Variant.Outlined"
                          InputType="@(_showPwd ? InputType.Text : InputType.Password)"
                          Adornment="Adornment.End"
                          AdornmentIcon="@(_showPwd ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                          OnAdornmentClick="() => _showPwd = !_showPwd"
                          Class="mb-3"
                          Immediate="true"
                          Disabled="@_saving" />

            <MudTextField @bind-Value="_confirm"
                          Label="Confirm password"
                          Variant="Variant.Outlined"
                          InputType="@(_showPwd ? InputType.Text : InputType.Password)"
                          Class="mb-4"
                          Immediate="true"
                          Disabled="@_saving" />

            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mb-3">@_error</MudAlert>
            }

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       Disabled="@_saving"
                       OnClick="SubmitAsync">
                @(_saving ? "Setting password…" : "Set password")
            </MudButton>
        }
    </MudPaper>
    <div style="position:absolute;bottom:16px;left:20px;font-size:0.7rem;opacity:0.4;user-select:none;">
        v@_version
    </div>
</div>

@code {
    [SupplyParameterFromQuery] private string? Token { get; set; }

    private bool    _loading     = true;
    private bool    _saving      = false;
    private bool    _success     = false;
    private bool    _showPwd     = false;
    private string? _tokenError;
    private string? _username;
    private string? _displayName;
    private string  _password    = "";
    private string  _confirm     = "";
    private string  _error       = "";
    private string  _version     = "";

    protected override async Task OnInitializedAsync() =>
        _version = await AppInfo.GetVersionAsync();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Task.Delay(1);
        if (string.IsNullOrWhiteSpace(Token))
        {
            _tokenError = "No token provided. Use the link from your invitation email.";
            _loading    = false;
            StateHasChanged();
            return;
        }
        var (ok, username, displayName, error) = await Auth.ValidateSetPasswordTokenAsync(Token);
        if (!ok)
            _tokenError = error ?? "Invalid or expired link.";
        else
        {
            _username    = username;
            _displayName = displayName;
        }
        _loading = false;
        StateHasChanged();
    }

    private async Task SubmitAsync()
    {
        _error = "";
        if (_password.Length < 8)
        {
            _error = "Password must be at least 8 characters.";
            return;
        }
        if (_password != _confirm)
        {
            _error = "Passwords do not match.";
            return;
        }
        _saving = true;
        var (ok, err) = await Auth.SetPasswordAsync(Token!, _password);
        _saving = false;
        if (ok)
            _success = true;
        else
            _error = err ?? "An error occurred.";
    }
}
