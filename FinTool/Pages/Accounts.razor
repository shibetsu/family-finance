@page "/accounts"
@inject AccountService AccountSvc
@using FinTool.Models
@using FinTool.Services

<PageTitle>Accounts – FinTool</PageTitle>

@if (_loading)
{
    <LoadingOverlay />
}
else
{
    <MudStack Row AlignItems="AlignItems.Center" Class="mb-6">
        <MudText Typo="Typo.h5">Accounts</MudText>
        <MudSpacer />
        <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled"
                   Color="Color.Primary" Size="Size.Small" OnClick="AddAccount">
            Add Account
        </MudButton>
    </MudStack>

    @if (_accounts.Count == 0)
    {
        <MudPaper Elevation="0" Class="pa-10"
                  Style="text-align:center;border:2px dashed var(--mud-palette-divider);border-radius:12px">
            <MudIcon Icon="@Icons.Material.Filled.AccountBalance"
                     Style="font-size:3rem;opacity:0.3" Class="mb-3" />
            <MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mb-1">No accounts yet</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                Add your bank accounts and credit cards to track which account each transaction belongs to.
            </MudText>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled"
                       Color="Color.Primary" OnClick="AddAccount">
                Add your first account
            </MudButton>
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="1" Class="pa-4">
            <MudText Typo="Typo.subtitle1" Class="mb-3">Your Accounts</MudText>

            <!-- Column headers -->
            <div style="display:grid;grid-template-columns:28px 1fr 140px 32px;gap:8px;align-items:center;padding:0 0 6px;border-bottom:1px solid var(--mud-palette-divider);margin-bottom:4px">
                <div></div>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Account Name</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Type</MudText>
                <div></div>
            </div>

            @foreach (var acct in _accounts)
            {
                var a = acct;
                <div style="display:grid;grid-template-columns:28px 1fr 140px 32px;gap:8px;align-items:center;padding:4px 0">
                    <!-- Color picker -->
                    <InlineColorPicker Value="@a.Color"
                                       ValueChanged="@(async v => { a.Color = v; await SaveAsync(a); })" />

                    <!-- Name -->
                    <input value="@a.Name"
                           @onchange="@(async e => { a.Name = e.Value?.ToString() ?? a.Name; await SaveAsync(a); })"
                           placeholder="Account name"
                           style="border:none;border-bottom:1px solid var(--mud-palette-divider);outline:none;background:transparent;font-size:0.875rem;color:inherit;width:100%;padding:2px 0" />

                    <!-- Type -->
                    <MudSelect T="string" Value="@a.Type"
                               ValueChanged="@(async v => { a.Type = v; await SaveAsync(a); })"
                               Dense Variant="Variant.Outlined" Margin="Margin.Dense"
                               Style="font-size:0.875rem">
                        <MudSelectItem Value="@("credit")">Credit Card</MudSelectItem>
                        <MudSelectItem Value="@("debit")">Debit / Chequing</MudSelectItem>
                        <MudSelectItem Value="@("savings")">Savings</MudSelectItem>
                    </MudSelect>

                    <!-- Delete -->
                    <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small"
                                   Color="Color.Default"
                                   OnClick="@(async () => await DeleteAsync(a))" />
                </div>
            }

            <MudButton StartIcon="@Icons.Material.Filled.Add" Size="Size.Small"
                       Variant="Variant.Text" Color="Color.Default" Class="mt-2"
                       OnClick="AddAccount">
                Add account
            </MudButton>
        </MudPaper>
    }
}

@code {
    private bool          _loading  = true;
    private List<Account> _accounts = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Task.Delay(1);
        _accounts = await AccountSvc.GetAllAsync();
        _loading  = false;
        StateHasChanged();
    }

    private async Task AddAccount()
    {
        _accounts.Add(new Account { Name = "", Color = ColorPalette.Random() });
        await Task.CompletedTask;
    }

    private async Task SaveAsync(Account account)
    {
        if (!string.IsNullOrWhiteSpace(account.Name))
            await AccountSvc.SaveAsync(account);
    }

    private async Task DeleteAsync(Account account)
    {
        _accounts.Remove(account);
        if (account.Name.Length > 0)
            await AccountSvc.DeleteAsync(account.Id);
    }
}
