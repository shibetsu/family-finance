@page "/transactions"
@attribute [Authorize]
<PageTitle>Transactions – FinTool</PageTitle>
<TransactionsTab InitialMonth="@Month" InitialCategory="@Category" />

@code {
    [SupplyParameterFromQuery(Name = "month")]
    public string? Month { get; set; }

    [SupplyParameterFromQuery(Name = "category")]
    public string? Category { get; set; }
}
